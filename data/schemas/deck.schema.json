{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://project-stack.local/schemas/deck.schema.json",
  "title": "Project S.T.A.C.K. Deck Definition",
  "description": "Shared structure for a Project S.T.A.C.K. deck recipe. Cross-card checks are performed by the repository validator.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "active",
    "deckType",
    "name",
    "revision",
    "tags",
    "rulesText",
    "data"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$",
      "description": "Permanent unique deck-definition ID."
    },
    "active": {
      "type": "boolean",
      "description": "Whether this deck recipe may be selected for normal playtesting."
    },
    "deckType": {
      "type": "string",
      "pattern": "^[a-z][A-Za-z0-9]*$",
      "description": "Deck category, such as dungeon, loot, status, or market."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Exact deck name for display and scenario setup."
    },
    "revision": {
      "type": "integer",
      "minimum": 1,
      "description": "Deck-design revision number."
    },
    "moduleId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$",
      "description": "Optional module or expansion identifier."
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
      },
      "description": "Machine-readable deck, theme, and setup tags."
    },
    "rulesText": {
      "type": "string",
      "minLength": 1,
      "description": "Player-facing or playtester-facing description of the deck's intended use."
    },
    "data": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "cardEntries",
        "totalCardCount"
      ],
      "properties": {
        "cardEntries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "cardId",
              "quantity"
            ],
            "properties": {
              "cardId": {
                "type": "string",
                "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
              },
              "quantity": {
                "type": "integer",
                "minimum": 1
              }
            }
          }
        },
        "totalCardCount": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sourceFile": {
          "type": "string"
        },
        "sourceSection": {
          "type": "string"
        },
        "verifiedAgainstRulebook": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
